{
  "name": "@fused-gaming/mermaid-terminal",
  "version": "1.0.0",
  "description": "Generate, render, and export Mermaid diagrams directly from CLI. Create flowcharts, sequence diagrams, state machines, and more with terminal preview support. Includes real-time editing, format conversion, and image export.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TrystPilot/skills",
    "directory": "packages/mermaid-terminal"
  },
  "bin": {
    "mermaid": "./dist/cli.js"
  },
  "keywords": [
    "mermaid",
    "diagram",
    "cli",
    "terminal",
    "flowchart",
    "sequence",
    "visualization"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE.txt"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^10.0.0",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "ora": "^6.1.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.40.0",
    "typescript": "^5.0.0",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
