# ============================================================
# finance-assistant .gitignore
# 保护本地敏感金融数据，以下文件/目录不会上传到 Git 仓库
# ============================================================

# ── 持仓原始导出文件（含股东账号、成本价等隐私数据）────────────────
holdings/

# ── 持仓快照 JSON（含总资产、每只ETF成本/市值/盈亏）────────────────
reports/*-holdings-snapshot.json

# ── 持仓历史记忆（含每日总市值演变，隐私数据）──────────────────────
memory/

# ── 回测沙盒（从 memory/ 拷贝数据，独立测试，不影响真实记录）────────
backtesting/sandbox/


# ── 盘后脚本采集的原始 JSON 数据────────────────────────────────────
post-market-review/scripts/output/

# ── 临时调试脚本────────────────────────────────────────────────────
_*.py
_*.txt

# ── Python 缓存────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# ── 编辑器/系统文件────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
