# ─── AI Content Generation ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Media (Free tier available) ─────────────────────────────────────────────
# Sign up at https://www.pexels.com/api/
PEXELS_API_KEY=

# ─── News Data (Free tier: 100 req/day) ──────────────────────────────────────
# Sign up at https://newsapi.org/
NEWS_API_KEY=

# ─── YouTube Upload ───────────────────────────────────────────────────────────
# Get from https://console.cloud.google.com → Enable YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Generated on first run via: python main.py setup --platform youtube
YOUTUBE_REFRESH_TOKEN=

# ─── TikTok Upload ────────────────────────────────────────────────────────────
# Apply for Content Posting API at https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ─── App Behaviour ────────────────────────────────────────────────────────────
VIDEOS_PER_DAY=8
OUTPUT_DIR=output
UPLOAD_TO_YOUTUBE=true
UPLOAD_TO_TIKTOK=true

# Duration (seconds)
YOUTUBE_VIDEO_DURATION=300
TIKTOK_VIDEO_DURATION=60

# TTS language code
TTS_LANGUAGE=en

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
