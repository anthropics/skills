{
  "name": "ai-tells-validator",
  "version": "0.2.0",
  "description": "Detect and rewrite AI-sounding text. Grounded in the live Wikipedia 'Signs of AI writing' catalog.",
  "type": "module",
  "bin": {
    "ai-tells-validate": "./scripts/validate.mjs",
    "ai-tells-rewrite": "./scripts/rewrite.mjs"
  },
  "scripts": {
    "validate": "node scripts/validate.mjs",
    "rewrite": "node scripts/rewrite.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": ["claude", "claude-code", "skill", "ai-writing", "outbound", "copywriting", "wikipedia"],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "SKILL.md",
    "README.md",
    "LICENSE",
    "lib/",
    "scripts/",
    "tests/"
  ]
}
