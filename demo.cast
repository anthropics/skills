[68.263006, "o", "\u001b[?2026h\r\u001b[2C\u001b[5A-\u001b[1CThe\u001b[1Ccompromised\u001b[1Csigner\u001b[1Cshould\u001b[1Cgenerate\u001b[1Ca\u001b[1Cnew\u001b[1Ckey\u001b[1Con\u001b[1Ca\u001b[1C\u001b[1mfresh hardware wallet\r\u001b[1B\u001b[22m                                                                                                                                                                        \r\u001b[1B\u001b[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                     \r\u001b[1B\u001b[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[2C\u001b[38;5;246mesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\n\u001b[?2026l"]
[68.726812, "o", "\u001b[?2026h\r\u001b[2C\u001b[8A-\u001b[1CInitiate\u001b[1Ca\u001b[1CSafe\u001b[1Ctransaction\u001b[1Cto\u001b[1C\u001b[1mswap the compromised signer address\u001b[1C\u001b[22mfor\u001b[1Ca\u001b[1Cnew,\u001b[1Cclean\u001b[1Caddress\r\u001b[4C\u001b[1BThe compromised\u001b[1Csig\u001b[1Cer sh\u001b[1Culd generate a new key on a \u001b[1mfr\u001b[1Csh ha\u001b[1Cdware wallet\u001b[22m  \u001b[1C     \u001b[1C       \r\u001b[4C\u001b[1BGet\u001b[1C3 of the 4 unaff\u001b[1Ccted signers to approve\u001b[1Cand\u001b[1Cexecute this transaction  \r\u001b[2B  \u001b[1m4. Contact SEAL 911 if funds are at risk\u001b[22m                                                                                                                              \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m               \r\r\n\u001b[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[2C\u001b[38;5;246mesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\n\u001b[?2026l"]
