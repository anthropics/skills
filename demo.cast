[25.128154, "o", "\u001b[?2026h\r\u001b[6A\u001b[38;5;231m●\u001b[1C\u001b[39mGood setup to start with\u001b[1C—\u001b[1C3-of-5\u001b[1Cis\u001b[1Ca\u001b[1Csolid\u001b[1Cthreshold.\u001b[1CLet\u001b[1Cme\u001b[1Cwalk\u001b[1Cyou\u001b[1Cthrough\u001b[1Cthe\u001b[1Ckey\u001b[1Careas\u001b[1Cto\u001b[1Caudit.\r\u001b[2B  ---                                                                                                                                                                   \r\u001b[1B   \r\u001b[1B  \u001b[1mMultisig Security Posture Check: 3-of-5 Gnosis Safe\u001b[22m                                                                                                                   \r\u001b[2C\u001b[1B                \u001b[130C                  \r\r\n\u001b[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\n\u001b[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[2C\u001b[38;5;246mesc\u001b[1Cto\u001b[1Cinterrupt\u001b[130C◐\u001b[1Cmedium\u001b[1C·\u001b[1C/effort\u001b[39m\r\r\n\u001b[?2026l"]
[25.466079, "o", "\u001b]0;⠐ Audit DeFi protocol multisig security posture\u0007"]
[25.517335, "o", "\u001b[?2026h\r\u001b[2C\u001b[7A\u001b[1mMultisig Security Posture Check: 3-of-5 Gnosis Safe\r\u001b[2C\u001b[1B\u001b[22m                                                   \r\u001b[2C\u001b[1B\u001b[1mSigner Setup\r\u001b[1B\u001b[22m                                                                                                                                                                        \r\u001b[1B\u001b[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                     \r\u001b[1B\u001b[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[2C\u001b[38;5;246mesc\u001b[1Cto\u001b[1Cinterrupt\u001b[130C◐\u001b[1Cmedium\u001b[1C·\u001b[1C/effort\u001b[39m\r\r\n\u001b[?2026l"]
[26.330744, "o", "\u001b[?2026h\r\u001b[4A  - All 5 signers using \u001b[1mhardware wallets\u001b[22m (Ledger/Trezor) — no software wallets as signers                                                                               \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m               \u001b[130C                  \r\r\n\u001b[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[2C\u001b[38;5;246mesc\u001b[1Cto\u001b[1Cinterrupt\u001b[130C◐\u001b[1Cmedium\u001b[1C·\u001b[1C/effort\u001b[39m\r\r\n\u001b[?2026l"]
