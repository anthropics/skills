[70.041016, "o", "\u001b[?2026h\r\u001b[4A  If you suspect active exploitation or see suspicious transactions, reach out to the \u001b[1mSEAL 911 war room\u001b[22m for coordinated response — don't go solo on an active incident. \r\u001b[1B   \r\u001b[1B  ---                                                                                                                                                                   \r\u001b[2C\u001b[1B                \r\r\n\u001b[2C\u001b[1mAfter\u001b[1CImmediate\u001b[1CContainment\u001b[22m\r\r\n\r\r\n\u001b[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\n\u001b[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[2C\u001b[38;5;246mesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\n\u001b[?2026l"]
[70.939172, "o", "\u001b[?2026h\r\u001b[2C\u001b[7A\u001b[1mAfter Immediate Containment\r\u001b[2C\u001b[1B\u001b[22m                           \r\u001b[2C\u001b[1B-\u001b[1CAudit\u001b[1C\u001b[1mall recent Safe transactions\u001b[1C\u001b[22m—\u001b[1Clook\u001b[1Cfor\u001b[1Canything\u001b[1Csigned\u001b[1Cfrom\u001b[1Cthat\u001b[1Csigner\u001b[1Cin\u001b[1Cthe\u001b[1Clast\u001b[1C30\u001b[1Cdays\r\u001b[1B                                                                                                                                                                        \r\u001b[1B\u001b[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                     \r\u001b[1B\u001b[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[2C\u001b[38;5;246mesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\n\u001b[?2026l"]
